{
  "display_information": {
    "name": "Gemini Slack Bot"
  },
  "features": {
    "bot_user": {
      "display_name": "Gemini Slack Bot",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "files:read",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "__REQUEST_URL__",
      "bot_events": [
        "message.channels",
        "file_shared"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
